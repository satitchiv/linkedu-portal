<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>School Recommendations — LinkedU Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Inter', sans-serif; background: #f5f0e8; color: #1a1a1a; min-height: 100vh; }

  .header { background: #1a1a1a; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; }
  .header-logo { font-family: 'Playfair Display', serif; color: #B8962E; font-size: 20px; }
  .header-sub { color: #888; font-size: 12px; margin-top: 2px; }

  .container { max-width: 780px; margin: 0 auto; padding: 24px 16px 60px; }

  .student-card { background: #1a1a1a; color: #f5f0e8; border-radius: 10px; padding: 18px 20px; margin-bottom: 24px; }
  .student-name { font-family: 'Playfair Display', serif; font-size: 20px; color: #B8962E; }
  .student-meta { font-size: 12px; color: #888; margin-top: 4px; }

  .section-title { font-size: 11px; text-transform: uppercase; letter-spacing: .1em; color: #888; margin-bottom: 12px; }

  .school-card { background: #fff; border-radius: 10px; padding: 16px 18px; margin-bottom: 12px; border: 2px solid transparent; transition: border-color .15s; }
  .school-card.selected { border-color: #B8962E; background: #fffdf7; }

  .school-top { display: flex; align-items: flex-start; gap: 14px; }
  .school-checkbox { width: 22px; height: 22px; border-radius: 50%; border: 2px solid #ddd; display: flex; align-items: center; justify-content: center; flex-shrink: 0; cursor: pointer; margin-top: 2px; transition: all .15s; }
  .school-checkbox.checked { background: #B8962E; border-color: #B8962E; }
  .school-checkbox.checked::after { content: '✓'; color: #fff; font-size: 13px; font-weight: 700; }

  .school-info { flex: 1; }
  .school-name { font-size: 15px; font-weight: 600; color: #1a1a1a; }
  .school-meta { font-size: 12px; color: #888; margin-top: 3px; }
  .school-score { text-align: right; flex-shrink: 0; }
  .score-num { font-size: 22px; font-weight: 700; font-family: 'Playfair Display', serif; }
  .score-num.strong { color: #27ae60; }
  .score-num.good   { color: #B8962E; }
  .score-num.consider { color: #888; }
  .tier-badge { font-size: 10px; color: #888; margin-top: 2px; }

  .reasons { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 10px; }
  .reason-tag { background: rgba(184,150,46,.1); color: #7a6020; font-size: 11px; padding: 3px 8px; border-radius: 20px; }

  .note-area { margin-top: 12px; display: none; }
  .school-card.selected .note-area { display: block; }
  .note-area label { font-size: 11px; text-transform: uppercase; letter-spacing: .08em; color: #888; display: block; margin-bottom: 6px; }
  .note-area textarea { width: 100%; padding: 10px 12px; border: 1px solid #ddd; border-radius: 6px; font-size: 13px; font-family: 'Inter', sans-serif; resize: vertical; outline: none; color: #1a1a1a; }
  .note-area textarea:focus { border-color: #B8962E; }

  .empty { text-align: center; padding: 60px 20px; color: #888; }

  .submit-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #1a1a1a; padding: 14px 24px; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
  .submit-count { color: #888; font-size: 13px; }
  .submit-count span { color: #B8962E; font-weight: 600; }
  .submit-btn { background: #B8962E; color: #fff; border: none; border-radius: 6px; padding: 12px 28px; font-size: 14px; font-weight: 600; font-family: 'Inter', sans-serif; cursor: pointer; transition: opacity .15s; }
  .submit-btn:disabled { opacity: .5; cursor: not-allowed; }
  .submit-msg { color: #B8962E; font-size: 13px; }

  .loading { text-align: center; padding: 80px 20px; color: #888; font-size: 14px; }
</style>
</head>
<body>

<div class="header">
  <div>
    <div class="header-logo">LinkedU</div>
    <div class="header-sub">School Recommendations — Consultant Review</div>
  </div>
</div>

<div class="container">
  <div id="loading" class="loading">Loading recommendations…</div>
  <div id="main" style="display:none">
    <div class="student-card" id="student-card"></div>
    <div class="section-title" id="rec-count"></div>
    <div id="schools-list"></div>
  </div>
  <div id="error" style="display:none" class="empty"></div>
</div>

<div class="submit-bar">
  <div class="submit-count">Selected: <span id="selected-count">0</span> schools</div>
  <div id="submit-msg" class="submit-msg"></div>
  <button class="submit-btn" id="submit-btn" onclick="submitApprovals()" disabled>
    Send to Parent →
  </button>
</div>

<script>
const params  = new URLSearchParams(location.search)
const studentId = params.get('student')
const secret    = params.get('secret')

let recommendations = []
let studentData = null

async function load() {
  if (!studentId || !secret) {
    show('error', 'Missing student ID or secret. Check your link.')
    return
  }

  try {
    // Fetch recommendations from Supabase REST
    const url = `https://ufspivvuevllmkxmivbe.supabase.co/rest/v1/student_recommendations?student_id=eq.${studentId}&order=score.desc`
    const res = await fetch(url, {
      headers: {
        'apikey': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVmc3BpdnZ1ZXZsbG1reG1pdmJlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMxMTU2MDUsImV4cCI6MjA4ODY5MTYwNX0.aybHZVeG4_gl5RDXjrhfTAKNq0sUEdYslwuwTdghIpk',
        'Authorization': 'Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVmc3BpdnZ1ZXZsbG1reG1pdmJlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMxMTU2MDUsImV4cCI6MjA4ODY5MTYwNX0.aybHZVeG4_gl5RDXjrhfTAKNq0sUEdYslwuwTdghIpk',
      }
    })
    recommendations = await res.json()

    // Fetch student name
    const sRes = await fetch(`https://ufspivvuevllmkxmivbe.supabase.co/rest/v1/students?id=eq.${studentId}&select=student_name,budget_gbp,primary_sport,destination`, {
      headers: {
        'apikey': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVmc3BpdnZ1ZXZsbG1reG1pdmJlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMxMTU2MDUsImV4cCI6MjA4ODY5MTYwNX0.aybHZVeG4_gl5RDXjrhfTAKNq0sUEdYslwuwTdghIpk',
        'Authorization': 'Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVmc3BpdnZ1ZXZsbG1reG1pdmJlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMxMTU2MDUsImV4cCI6MjA4ODY5MTYwNX0.aybHZVeG4_gl5RDXjrhfTAKNq0sUEdYslwuwTdghIpk',
      }
    })
    const students = await sRes.json()
    studentData = students[0] || {}

    render()
  } catch (err) {
    show('error', 'Failed to load: ' + err.message)
  }
}

function render() {
  if (!recommendations.length) {
    show('error', 'No recommendations generated yet. Trigger the algorithm first.')
    return
  }

  // Student card
  document.getElementById('student-card').innerHTML = `
    <div class="student-name">${studentData.student_name || 'Student'}</div>
    <div class="student-meta">
      Budget £${(studentData.budget_gbp || 0).toLocaleString()}/yr ·
      Sport: ${studentData.primary_sport || '—'} ·
      ${(studentData.destination || []).join(', ') || 'Destination not set'}
    </div>`

  document.getElementById('rec-count').textContent =
    `${recommendations.length} schools scored — select the ones to show this parent`

  const tierLabel = { strong_match: 'Strong Match', good_match: 'Good Match', consider: 'Consider' }
  const scoreClass = { strong_match: 'strong', good_match: 'good', consider: 'consider' }

  document.getElementById('schools-list').innerHTML = recommendations.map(r => `
    <div class="school-card ${r.approved ? 'selected' : ''}" id="card-${r.school_id}" onclick="toggleSchool(${r.school_id})">
      <div class="school-top">
        <div class="school-checkbox ${r.approved ? 'checked' : ''}" id="chk-${r.school_id}"></div>
        <div class="school-info">
          <div class="school-name">${r.school_name}</div>
          <div class="school-meta">${r.region || ''} · £${(r.fee || 0).toLocaleString()}/yr · ${r.school_type || ''}</div>
        </div>
        <div class="school-score">
          <div class="score-num ${scoreClass[r.tier]}">${r.score}</div>
          <div class="tier-badge">${tierLabel[r.tier]}</div>
        </div>
      </div>
      <div class="reasons">
        ${(r.match_reasons || []).map(reason => `<span class="reason-tag">${reason}</span>`).join('')}
      </div>
      <div class="note-area" onclick="event.stopPropagation()">
        <label>Your note to the parent about this school</label>
        <textarea id="note-${r.school_id}" rows="3" placeholder="e.g. Best fit for golf scholarship — recommend contacting admissions by October…">${r.consultant_note || ''}</textarea>
      </div>
    </div>`).join('')

  show('main')
  updateCount()
}

function toggleSchool(schoolId) {
  const card = document.getElementById('card-' + schoolId)
  const chk  = document.getElementById('chk-' + schoolId)
  const rec  = recommendations.find(r => r.school_id === schoolId)
  rec.approved = !rec.approved
  card.classList.toggle('selected', rec.approved)
  chk.classList.toggle('checked', rec.approved)
  updateCount()
}

function updateCount() {
  const count = recommendations.filter(r => r.approved).length
  document.getElementById('selected-count').textContent = count
  document.getElementById('submit-btn').disabled = count === 0
}

async function submitApprovals() {
  const btn = document.getElementById('submit-btn')
  const msg = document.getElementById('submit-msg')
  btn.disabled = true; btn.textContent = 'Saving…'
  msg.textContent = ''

  const approvals = recommendations.map(r => ({
    school_id:       r.school_id,
    approved:        r.approved,
    consultant_note: document.getElementById('note-' + r.school_id)?.value?.trim() || '',
  }))

  try {
    const res = await fetch('/api/approve-recommendations', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Admin-Secret': secret },
      body: JSON.stringify({ student_id: studentId, approvals })
    })
    const json = await res.json()
    if (!res.ok) throw new Error(json.error)

    msg.textContent = `✓ ${json.approvedCount} school${json.approvedCount !== 1 ? 's' : ''} sent to parent`
    btn.textContent = 'Saved ✓'
    setTimeout(() => { btn.textContent = 'Send to Parent →'; btn.disabled = false }, 3000)
  } catch (err) {
    msg.style.color = '#c0392b'; msg.textContent = 'Error: ' + err.message
    btn.disabled = false; btn.textContent = 'Send to Parent →'
  }
}

function show(id, msg) {
  document.getElementById('loading').style.display = 'none'
  document.getElementById('main').style.display    = id === 'main' ? 'block' : 'none'
  document.getElementById('error').style.display   = id === 'error' ? 'block' : 'none'
  if (msg) document.getElementById('error').textContent = msg
}

load()
</script>
</body>
</html>
